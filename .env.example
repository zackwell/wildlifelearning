# ========== 账号与数据库（Neon PostgreSQL）==========
# 在 https://console.neon.tech 创建 Project → Connection details → 复制连接串：
# DATABASE_URL=postgresql://user:pass@ep-xxx.region.aws.neon.tech/neondb?sslmode=require
#
# 首次配置后在本项目根目录执行：npm run db:push
# （会在 Neon 上自动创建 users / sessions / oauth_accounts 表）
#
# DATABASE_URL=
# AUTH_SECRET=随机长字符串（可选，预留后续 JWT；当前会话存数据库）

# ========== 方式 A：任意 OpenAI 兼容服务（含 Ollama 云端）==========
# 对话 + 嵌入共用同一 base 与 key（若嵌入模型在别处，需自行改代码拆 client）。
#
# Ollama 云端（OpenAI 兼容）：在 https://ollama.com/settings/keys 创建 API Key
# OPENAI_BASE_URL=https://ollama.com/v1
# OPENAI_API_KEY=你的_Ollama_API_Key
#
# 本地 Ollama（本机已运行 ollama serve）：
# OPENAI_BASE_URL=http://127.0.0.1:11434/v1
# OPENAI_API_KEY=ollama
#
# 也可用 Ollama 命名（与上面二选一即可，会回退读取）：
# OLLAMA_BASE_URL=https://ollama.com/v1
# OLLAMA_API_KEY=

# 对话模型（须为当前 host 上存在的模型名，例如 Ollama 库里的 cloud 模型名）
OPENAI_CHAT_MODEL=gpt-4o-mini

# 嵌入模型（Ollama 常用 nomic-embed-text 等；若接口不支持嵌入，问答仍可用关键词检索）
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# 混合问答：默认开启。无摘录命中时仍调用大模型做通识科普（开头须声明非本站摘录）；
# 有摘录时允许在「（通识补充）」小节下简短补充。设为 false 则回到「仅摘录」严格模式。
# RAG_HYBRID=true

# ---------- 探索动物配图 ----------
# 必应图片搜索 v7 等 API 已退役；配图改为 Unsplash + 维基。
# 在 https://unsplash.com/developers 创建应用，复制 Access Key：
#   UNSPLASH_ACCESS_KEY=
# 排查配图失败（看终端里 Unsplash HTTP 状态与错误片段）：
#   UNSPLASH_DEBUG=1
#
# 探索动物配图最多张数（Unsplash 轮播，默认 4，上限 20）：
# SPECIES_GALLERY_MAX=4
#
# SPECIES_IMAGE_SOURCE 取值（不区分大小写）：
#   auto（默认）— 有 Unsplash Key 时先试 Unsplash，再试维基
#   unsplash_only — 仅 Unsplash，不访问维基（国内维基不稳时可用）
#   bing_only — 兼容旧配置，等同于 unsplash_only（不再调用必应）
#   wiki_only / wikipedia — 仅维基
#   none — 不拉外网配图
#
# 探索动物 AI 图鉴：默认仅做「非空 + 不太短」的轻量校验；资料少的物种也可通过。
# 需要原先「详图鉴」硬性篇幅与 6 个小节等规则时：
#   EXPLORE_SPECIES_STRICT_DETAIL=1
# 完全跳过篇幅校验（不推荐常规开启）：
#   EXPLORE_SPECIES_RELAX_DETAIL=1
# （二者同时设时以 RELAX 为准。）
# ========== 方式 B：官方 OpenAI ==========
# OPENAI_API_KEY=
# OPENAI_BASE_URL=
